{
  "name": "@ttc-tornooiapp/web",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "predev": "node ../scripts/update-build-info.mjs",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node ../scripts/update-build-info.mjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test -c e2e/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test -c e2e/playwright.config.ts --debug",
    "e2e:fixtures": "npx tsx e2e/scripts/build-fixtures.ts"
  },
  "dependencies": {
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "ttc-tornooiapp": "file:.."
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.6",
    "playwright": "^1.52.0",
    "svelte": "^5.46.4",
    "svelte-check": "^4.3.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
